APP_NAME=Teelab_APP
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=teelabdatabase
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# Xendit Payment Gateway

XENDIT_SECRET_KEY=xnd_public_development_1234567890abcdefghijklmnopqrstuvwxyz
XENDIT_WEBHOOK_TOKEN=1234567890abcdefghijklmnopqrstuvwxyz
XENDIT_ENV=production/sandbox
XENDIT_SUCCESS_REDIRECT_URL=http://localhost:5173/payment/success
XENDIT_FAILURE_REDIRECT_URL=http://localhost:5173/payment/failed