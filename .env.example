APP_NAME=Teelab_APP
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=teelabdatabase
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# Xendit Payment Gateway
# Get your keys from https://dashboard.xendit.co/settings/developers/api-keys
# For sandbox, use key starting with xnd_ (development) or xnd_production (production)

XENDIT_SECRET_KEY=xnd_public_development_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XENDIT_CALLBACK_TOKEN=your_callback_token_here
FRONTEND_URL=http://localhost:3000